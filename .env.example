# Public Supabase config (safe to ship — these are anon keys, no admin rights).
# Copy this file to .env and fill in the real values from
# https://supabase.com/dashboard/project/<your-project-ref>/settings/api

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: external error tracking. Leave blank to use only the in-app
# admin_error_events sink. If set, also install @sentry/react and wire
# up src/lib/sentryStub.ts.
VITE_SENTRY_DSN=

# Edge function env (set in Supabase dashboard, NOT here — never ship to client):
#
# Required for everything:
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY
#   ALLOWED_ORIGINS                 comma-separated list of browser origins
#
# AI provider chain (Google primary, OpenAI fallback, OpenRouter last):
#   GOOGLE_AI_API_KEY
#   OPENAI_API_KEY
#   OPENROUTER_API_KEY
#
# Court scraping + CAPTCHA:
#   TWOCAPTCHA_API_KEY              for check-case-judgment + sync-case-documents
#   FIRECRAWL_API_KEY               for scrape-causelist / scrape-live-board
#
# Alerts:
#   TELEGRAM_BOT_TOKEN              for alert-p0-errors
#   ADMIN_TELEGRAM_CHAT_ID
#
# Trigger callback authentication:
#   TRIGGER_SECRET                  verified by auto-match-aliases /
#                                   backfill-alias-matches
#
# Required Postgres settings (set with ALTER DATABASE … SET app.settings.x = '…'):
#   app.settings.supabase_url
#   app.settings.supabase_service_key
#   app.settings.supabase_anon_key
#   app.settings.trigger_secret
